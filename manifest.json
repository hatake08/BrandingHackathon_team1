{
  "manifest_version": 3,
  "name": "moodle+R ex",
  "version": "1.0",
  "description": "moodle+Rでの学習を最適化する機能を追加します",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.ritsumei.ac.jp/*",
    "https://syllabus.ritsumei.ac.jp/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://lms.ritsumei.ac.jp/*"],
      "js": [
        "js/moodle/announcement.js",
        "js/moodle/content.js",
        "js/moodle/getMoodle.js",
        "js/moodle/getSyllabus.js",
        "js/moodle/scoreDashbord.js",
        "js/moodle/connectCalendar.js",
        "js/moodle/drawer.js"
      ]
    },
    {
      "matches": ["https://syllabus.ritsumei.ac.jp/syllabus/s/*"],
      "js": ["js/syllabus/parseSyllabus.js"]
    },
    {
      "matches": ["https://lms.ritsumei.ac.jp/calendar/view.php*"],
      "js": ["js/moodle/connectCalendar.js"]
    }
  ]
}